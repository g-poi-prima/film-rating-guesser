generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MatchStatus {
  WAITING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum LobbyMode {
  ALL_VS_ALL
  TOURNAMENT
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games            Game[]
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  matchesAsPlayer1 Match[]         @relation("Player1")
  matchesAsPlayer2 Match[]         @relation("Player2")
  sentRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedRequests FriendRequest[] @relation("ReceivedFriendRequests")
  hostedLobbies    CustomMatch[]   @relation("LobbyHost")
  lobbyResults     CustomMatchResult[]
}

model Game {
  id            Int      @id @default(autoincrement())
  userId        Int
  movieId       Int
  movieTitle    String
  moviePoster   String?
  movieOverview String?
  userRating    Float
  realRating    Float
  score         Int
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Match {
  id           Int         @id @default(autoincrement())
  player1Id    Int
  player2Id    Int
  totalRounds  Int         @default(5)
  player1Score Int?
  player2Score Int?
  status       MatchStatus @default(WAITING)
  createdAt    DateTime    @default(now())
  endedAt      DateTime?

  player1 User         @relation("Player1", fields: [player1Id], references: [id])
  player2 User         @relation("Player2", fields: [player2Id], references: [id])
  rounds  MatchRound[]
}

model MatchRound {
  id            Int     @id @default(autoincrement())
  matchId       Int
  roundNumber   Int
  movieId       Int
  movieTitle    String
  moviePoster   String?
  movieOverview String?
  realRating    Float
  player1Rating Float?
  player2Rating Float?
  player1Score  Int?
  player2Score  Int?

  match Match @relation(fields: [matchId], references: [id])
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int?
  content    String
  createdAt  DateTime @default(now())

  sender   User  @relation("SentMessages", fields: [senderId], references: [id])
  receiver User? @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model FriendRequest {
  id         Int              @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model CustomMatch {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String
  mode        LobbyMode
  hostId      Int
  totalRounds Int         @default(5)
  status      MatchStatus @default(WAITING)
  createdAt   DateTime    @default(now())
  endedAt     DateTime?

  host    User                @relation("LobbyHost", fields: [hostId], references: [id])
  results CustomMatchResult[]
}

model CustomMatchResult {
  id            Int @id @default(autoincrement())
  customMatchId Int
  userId        Int
  totalScore    Int @default(0)
  rank          Int

  match CustomMatch @relation(fields: [customMatchId], references: [id])
  user  User        @relation(fields: [userId], references: [id])

  @@unique([customMatchId, userId])
}
