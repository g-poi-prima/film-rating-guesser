generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games Game[]
}

model Game {
  id            Int      @id @default(autoincrement())
  userId        Int
  movieId       Int
  movieTitle    String
  moviePoster   String?
  movieOverview String?
  userRating    Float
  realRating    Float
  score         Int
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
